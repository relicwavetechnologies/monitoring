generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  receivesAlerts Boolean   @default(true)
  accounts       Account[]
  sessions       Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Monitoring Models ────────────────────────────────────────────────────────

enum RenderMode {
  STATIC
  JS
}

enum ChangeCategory {
  POLICY_CHANGE
  FEE_CHANGE
  APPOINTMENT
  DOCUMENT_REQUIREMENT
  NAVIGATION
  COSMETIC
  UNKNOWN
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model Site {
  id                  String     @id @default(cuid())
  name                String
  url                 String
  // Phase 2b: site-level fields below remain on Site for backwards compat
  // and as defaults when creating a new MonitoredUrl. The pipeline now
  // reads the per-URL config from MonitoredUrl, not from these fields.
  renderMode          RenderMode @default(STATIC)
  contentSelector     String     @default("body")
  stripPatterns       String[]   @default([])
  pollIntervalMin     Int        @default(60)
  isActive            Boolean    @default(true)
  // Per-site policy tunables (Phase 1) — these stay on Site and are
  // inherited by every MonitoredUrl underneath it.
  minDiffChars        Int        @default(40)
  severityThreshold   Int        @default(3)
  confidenceThreshold Float      @default(0.7)
  confirmAfterHours   Int        @default(24)
  maxCrawlDepth       Int        @default(2)
  maxCrawlPages       Int        @default(20)
  // Mirror of MAX(monitoredUrls.lastCheckedAt) so the dashboard freshness
  // query stays a single index lookup. Updated by the pipeline.
  lastCheckedAt       DateTime?
  // Phase 2b: pendingDiff has moved to MonitoredUrl.pendingDiff. This field
  // is left in place to avoid breaking any legacy reads but is no longer
  // written by the pipeline. To be dropped in a later phase.
  pendingDiff         Json?
  aiAnalysis          String?    @db.Text
  aiAnalysisAt        DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  snapshots           Snapshot[]
  changes             Change[]
  monitoredUrls       MonitoredUrl[]
}

/// One concrete URL on a Site that the pipeline polls. A Site is the logical
/// container ("US Embassy Mumbai"); a MonitoredUrl is a specific page on
/// that site we're actually watching ("/mumbai/", "/mumbai/visas/", …).
///
/// Per-URL fields (selector, strip patterns, render mode, paused, pendingDiff)
/// live here because they vary page-by-page. Per-site policy (severity
/// thresholds, confirm window, etc.) stays on the parent Site.
model MonitoredUrl {
  id              String     @id @default(cuid())
  siteId          String
  url             String
  // Per-URL extraction config. Defaults are copied from the parent Site
  // when a MonitoredUrl is created and can be overridden afterwards.
  contentSelector String     @default("body")
  stripPatterns   String[]   @default([])
  renderMode      RenderMode @default(STATIC)
  /// `true` skips this URL on the next cron tick without removing the row.
  paused          Boolean    @default(false)
  lastCheckedAt   DateTime?
  /// Per-URL stability state (Phase 2b moves it from Site.pendingDiff).
  pendingDiff     Json?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  site            Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  snapshots       Snapshot[]
  changes         Change[]

  @@unique([siteId, url], map: "MonitoredUrl_siteId_url_key")
  @@index([siteId, paused, lastCheckedAt])
}

model Snapshot {
  id          String   @id @default(cuid())
  /// Phase 2b: every snapshot now belongs to a specific URL. Backfilled
  /// from Site at migration time; new rows always have it set.
  monitoredUrlId String
  /// Denorm pointer to the MonitoredUrl's parent Site. Kept for fast
  /// "all snapshots for this site" lookups without a join.
  siteId      String
  contentHash String
  // Phase 2a: reorder-resilient hash over the *set* of block hashes.
  // Nullable so legacy rows (created pre-Phase-2a) stay valid; the runtime
  // falls back to contentHash for those.
  blocksHash      String?
  // Which extraction strategy produced the blocks for this snapshot.
  // Valid values: SELECTOR, READABILITY, BODY. Stored as String so we
  // can add new tiers without an enum migration each time.
  extractStrategy String   @default("SELECTOR")
  htmlGz      Bytes
  textGz      Bytes
  fetchedAt   DateTime @default(now())
  httpStatus  Int      @default(200)
  monitoredUrl MonitoredUrl @relation(fields: [monitoredUrlId], references: [id], onDelete: Cascade)
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  blocks      SnapshotBlock[]

  @@index([siteId, fetchedAt(sort: Desc)])
  @@index([siteId, blocksHash])
  @@index([monitoredUrlId, fetchedAt(sort: Desc)])
  @@index([monitoredUrlId, blocksHash])
}

/// One block of extracted content from a snapshot — typically a paragraph,
/// heading, list item, or table cell. Block-level storage lets the diff
/// engine treat a reordered page as unchanged while still spotting edits.
model SnapshotBlock {
  id         String   @id @default(cuid())
  snapshotId String
  /// Position in document order — used for human-readable display.
  idx        Int
  /// SHA-256 of `kind + ':' + normalised(text)`. Identical text in the
  /// same kind always produces the same hash, so set operations are exact.
  blockHash  String
  /// The block's text content, post strip-pattern, post-normalisation.
  text       String   @db.Text
  /// HTML element kind: h1, h2, h3, h4, h5, h6, p, li, td, pre, blockquote,
  /// dt, dd. Lowercased.
  kind       String
  snapshot   Snapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId, idx])
  @@index([snapshotId, blockHash])
}

model Change {
  id                 String         @id @default(cuid())
  /// Phase 2b: every change now belongs to a specific URL. Backfilled
  /// from Site at migration time; new rows always have it set.
  monitoredUrlId     String
  /// Denorm pointer to the MonitoredUrl's parent Site. Kept for fast
  /// "all changes for this site" lookups without a join.
  siteId             String
  fromSnapshotId     String?
  toSnapshotId       String
  // Content-hash idempotency (Phase 1): re-running a poll over the same hash
  // transition is rejected by the unique constraint below.
  fromContentHash    String?
  toContentHash      String
  category           ChangeCategory @default(UNKNOWN)
  severity           Int
  confidence         Float
  summary            String
  detail             String?        @db.Text
  diffText           String         @db.Text
  // Email delivery state (Phase 1): replaces the old emailSent boolean.
  emailStatus        EmailStatus    @default(PENDING)
  emailAttempts      Int            @default(0)
  lastEmailError     String?        @db.Text
  lastEmailAttemptAt DateTime?
  detectedAt         DateTime       @default(now())
  monitoredUrl       MonitoredUrl   @relation(fields: [monitoredUrlId], references: [id], onDelete: Cascade)
  site               Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)

  // NB: the actual DB index also uses NULLS NOT DISTINCT (see migration 0001).
  // Prisma 7's prisma-client generator does not yet expose nullsNotDistinct,
  // so the schema declares the columns and the migration owns the SQL nuance.
  // Phase 2b: idempotency now scoped per-URL, not per-Site, so two URLs on
  // the same Site can independently produce a change with the same hash
  // transition (e.g. two pages both showing the same fee number).
  @@unique([monitoredUrlId, fromContentHash, toContentHash], map: "Change_monitoredUrlId_fromContentHash_toContentHash_key")
  @@index([siteId, detectedAt(sort: Desc)])
  @@index([severity, detectedAt(sort: Desc)])
  @@index([emailStatus, lastEmailAttemptAt])
  @@index([monitoredUrlId, detectedAt(sort: Desc)])
}

model SerperHit {
  id               String    @id @default(cuid())
  query            String
  url              String
  title            String
  snippet          String
  publishedAt      DateTime?
  seenAt           DateTime  @default(now())
  promotedToSiteId String?

  @@unique([query, url])
  @@index([seenAt(sort: Desc)])
}
